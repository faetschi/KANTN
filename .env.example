# APP_URL: The URL where this app is hosted. Configure as needed for OAuth callbacks and API endpoints.
APP_URL="http://localhost:4000"

# Supabase settings (client keys)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Optional: enable dev auth fallback when running locally
# Set to 'true' to allow `AuthService` dev login on localhost
ENABLE_DEV_AUTH=false
